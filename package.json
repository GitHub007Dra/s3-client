{
  "name": "s3-client",
  "private": true,
  "version": "0.0.0",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"wait-on http://localhost:5173 && electron .\" \"vite\"",
    "build": "vite build && node build.js && electron-builder --config electron-builder.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@tailwindcss/postcss": "^4.2.1",
    "aws-sdk": "^2.1693.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/node": "^24.10.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lucide-react": "^0.575.0",
    "postcss": "^8.5.6",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.s3-client.app",
    "productName": "S3 Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "!dist/mac-arm64",
      "!dist/S3 Client*.dmg",
      "!dist/S3 Client*.dmg.blockmap",
      "!dist/latest-mac.yml"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "extraMetadata": {
      "main": "dist/main/index.js"
    }
  }
}
